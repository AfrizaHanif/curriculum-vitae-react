# This folder is managed by the root .htaccess

# Local rules here are kept minimal to prevent redirect loops

<IfModule mod_rewrite.c>
  RewriteEngine On

# Safety net: If the browser hits the /current/ folder directly, push it back to the clean URL

# This handles cases where Apache skips the root .htaccess rules

# 1. Handle index.html cleanup (Root and Nested)

# /current/index.html -> /  AND  /current/resume/index.html -> /resume/

  RewriteCond %{THE_REQUEST} \ /current/index\.html [NC,OR]
  RewriteCond %{THE_REQUEST} \ /current/(.+)/index\.html [NC]
  RewriteRule ^ /%1 [R=301,L]

# 2. Handle /current/ (empty) or /current/path -> /path

# We use (\S*) instead of (\S+) to allow matching empty strings after /current/

  RewriteCond %{THE_REQUEST} \ /current/(\S*) [NC]
  RewriteRule ^ /%1 [R=301,L]

  RewriteBase /

</IfModule>
DirectoryIndex index.html
Options -Indexes
