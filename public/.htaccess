<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

# 1. If the request is for an existing file (images, css, etc), serve it

RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# 2. If the request is for a path that exists as a .html file, serve that file

# This allows /about to serve about.html internally

RewriteCond %{REQUEST_FILENAME}.html -f [OR]
RewriteCond %{REQUEST_FILENAME}/index.html -f
RewriteRule ^(.\*)$ $1.html [NC,L]

# Handle 404 errors using the Next.js 404 page

ErrorDocument 404 /404.html
</IfModule>

# Optimize caching for static assets

<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# Prevent directory listing (fixes 403 if a folder exists without index.html)

Options -Indexes
